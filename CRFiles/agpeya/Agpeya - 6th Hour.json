[
  {
    "title": "Introduction of the Hour",
    "tbodies": [
      {
        "rows": [
          {
            "row-class": "text",
            "cells": [
              {
                "english": "In the name of the Father and the Son and the Holy Spirit, one God. Amen.",
                "coptic": "Ϧⲉⲛ ⲫ̀ⲣⲁⲛ ⲙ̀Ⲫⲓⲱⲧ ⲛⲉⲙ Ⲡϣⲏⲣⲓ ⲛⲉⲙ Ⲡⲓⲡ̀ⲛⲉⲩⲙⲁ ⲉⲑⲟⲩⲁⲃ ⲟⲩⲛⲟⲩϯ ⲛ̀ⲟⲩⲱⲧ: ⲁ̀ⲙⲏⲛ.",
                "arabic": "باسمِ الآبِ والابنِ والرّوحِ القُدُسِ الإلهِ الواحدِ. آمين."
              }
            ]
          },
          {
            "row-class": "text",
            "cells": [
              {
                "english": "Ⲕⲩⲣⲓⲉ ⲉ̀ⲗⲉⲏ̀ⲥⲟⲛ. Lord have mercy. Lord have mercy. Lord bless us. Amen.",
                "arabic": "Ⲕⲩⲣⲓⲉ ⲉ̀ⲗⲉⲏ̀ⲥⲟⲛ. ياربُّ ارحَمْ. ياربُّ ارحَمْ. ياربُّ بارِكْ. آمين."
              }
            ]
          },
          {
            "row-class": "text",
            "cells": [
              {
                "english": "Glory to the Father, and to the Son, and to the Holy Spirit. Now and ever and unto the ages of the ages. Amen.",
                "arabic": "المجدُ للآبِ والابنِ والرّوحِ القُدُسِ الآنَ وكلَّ أوانٍ وإلى دهرِ الدهورِ. آمين."
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "repeated_prayer_title": "The Lord's Prayer",
    "source": "AgpeyaPrayers",
